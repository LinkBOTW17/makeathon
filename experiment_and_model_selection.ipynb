    "## 2. Model Architecture Candidates\n",
    "\n",
    "To solve this challenge, we must aggregate temporal patterns (12 months of imagery) and fuse multiple data sources. Let's define the competitors:\n",
    "\n",
    "1.  **Baseline CNN (Naive)**: Simply averages the inputs over time and feeds them through standard CNN layers.\n",
    "2.  **Statistical FusionNet**: Extracts Min/Max/Mean over the temporal timeline (already present in the repository). This exposes anomaly variance to the network natively!\n",
    "3.  **LSTM FusionNet**: Extrapolates temporal dependencies step-by-step."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "model_baseline",
   "metadata": {},
   "outputs": [],
   "source": [
    "class BaselineNet(nn.Module):\n",
    "    \"\"\"A naive baseline that collapses time by averaging, then processes.\"\"\"\n",
    "    def __init__(self, s1_channels, s2_channels, aef_channels, num_classes=1):\n",
    "        super().__init__()\n",
    "        in_ch = s1_channels + s2_channels + aef_channels\n",
    "        self.conv = nn.Sequential(\n",
    "            nn.Conv2d(in_ch, 64, kernel_size=3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.Conv2d(64, 64, kernel_size=3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.Conv2d(64, num_classes, kernel_size=1)\n",
    "        )\n",
    "        \n",
    "    def forward(self, s1, s2, aef):\n",
    "        # Collapse temporal dimension via average\n",
    "        s1_mean = s1.mean(dim=1) if s1.dim() == 5 else s1\n",
    "        s2_mean = s2.mean(dim=1) if s2.dim() == 5 else s2\n",
    "        \n",
    "        # Fuse\n",
    "        if aef.dim() < 4:\n",
    "            aef = aef.unsqueeze(0)\n",
    "        # Ensure AEF matches height/width\n",
    "        if aef.shape[-2:] != s2_mean.shape[-2:]:\n",
    "            aef = F.interpolate(aef, size=s2_mean.shape[-2:], mode='bilinear', align_corners=False)\n",
    "            \n",
    "        x_fused = torch.cat([s1_mean, s2_mean, aef], dim=1)\n",
    "        return self.conv(x_fused)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "model_lstm",
   "metadata": {},
   "outputs": [],
   "source": [
    "class LSTMFusionNet(nn.Module):\n",
    "    \"\"\"Extracts features over time using a ConvLSTM.\"\"\"\n",
    "    def __init__(self, s1_channels, s2_channels, aef_channels, num_classes=1):\n",
    "        super().__init__()\n",
    "        self.s2_channels = s2_channels\n",
    "        self.s2_proj = nn.Conv2d(s2_channels, 32, kernel_size=3, padding=1)\n",
    "        \n",
    "        # A primitive approximation of ConvLSTM using separate Conv2d over flattened Time*Batch\n",
    "        self.lstm = nn.LSTM(input_size=32, hidden_size=64, batch_first=True)\n",
    "        \n",
    "        in_ch = s1_channels + 64 + aef_channels\n",
    "        self.decoder = nn.Sequential(\n",
    "            nn.Conv2d(in_ch, 128, kernel_size=3, padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.Conv2d(128, num_classes, kernel_size=1)\n",
    "        )\n",
    "        \n",
    "    def forward(self, s1, s2, aef):\n",
    "        B, T, C, H, W = s2.shape\n",
    "        # Flatten B and T to apply conv\n",
    "        s2_flat = s2.view(B*T, C, H, W)\n",
    "        s2_feat = self.s2_proj(s2_flat)   # (B*T, 32, H, W)\n",
    "        \n",
    "        # Prep for LSTM (Flatten Spatial)\n",
    "        s2_feat = s2_feat.view(B, T, 32, H*W).permute(0, 3, 1, 2) # (B, H*W, T, 32)\n",
    "        # We process each pixel as an independent sequence!\n",
    "        s2_feat = s2_feat.reshape(B * H * W, T, 32)\n",
    "        lstm_out, (hn, cn) = self.lstm(s2_feat)\n",
    "        out_time = hn[-1] # take last hidden state (B*H*W, 64)\n",
    "        \n",
    "        # Reshape back to image format\n",
    "        s2_lstm_feat = out_time.view(B, H, W, 64).permute(0, 3, 1, 2)\n",
    "        \n",
    "        s1_mean = s1.mean(dim=1) if s1.dim() == 5 else s1\n",
    "        if aef.dim() < 4:\n",
    "            aef = aef.unsqueeze(0)\n",
    "        if aef.shape[-2:] != s2_lstm_feat.shape[-2:]:\n",
    "            aef = F.interpolate(aef, size=s2_lstm_feat.shape[-2:], mode='bilinear', align_corners=False)\n",
    "            \n",
    "        fused = torch.cat([s1_mean, s2_lstm_feat, aef], dim=1)\n",
    "        return self.decoder(fused)"
   ]
  },
